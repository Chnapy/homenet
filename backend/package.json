{
  "name": "backend",
  "scripts": {
    "dev": "tsx --watch ./src/index.ts",
    "check": "tsc -p tsconfig.json",
    "build": "npx esbuild src/index.ts --bundle --outfile=dist/index.js --platform=node --target=node22 --packages=external --minify",
    "start": "node ./dist/index.js",
    "symlink:grpc": "ln -s ../protos ./protos",
    "gen:grpc": "protoc --plugin=./node_modules/.bin/protoc-gen-ts_proto --ts_proto_out=./src/grpc/generated/ --ts_proto_opt=outputServices=grpc-js ./protos/*.proto -I./protos"
  },
  "dependencies": {
    "@bufbuild/protobuf": "^2.2.5",
    "@fastify/cors": "^11.0.1",
    "@grpc/grpc-js": "^1.13.2",
    "@grpc/proto-loader": "^0.7.13",
    "@grpc/reflection": "^1.0.4",
    "@trpc/server": "^11.0.0",
    "fastify": "^5.2.2",
    "lmdb": "^3.2.6",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.13",
    "protoc": "^1.1.3",
    "ts-proto": "^2.7.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
